{
  "name": "beystadium",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "node scripts/serve.mjs",
    "data:build": "node scripts/build-data-index.mjs --build",
    "data:check": "node scripts/build-data-index.mjs --check",
    "audit:app": "node scripts/audit-app.mjs",
    "lint:js": "eslint scripts tests \"src/**/*.js\" playwright.config.mjs eslint.config.js",
    "test:search": "node --test tests/search-core.test.mjs",
    "test:ids": "node --test tests/x-bey-id.test.mjs",
    "test:address-ids": "node --test tests/address-id.test.mjs",
    "test:product-ids": "node --test tests/product-id.test.mjs",
    "test:burst-random-boosters": "node --test tests/burst-random-boosters.test.mjs",
    "test:burst-random-layers": "node --test tests/burst-random-layers.test.mjs",
    "test:x-tool-products": "node --test tests/x-tool-products.test.mjs",
    "test:x-set-products": "node --test tests/x-set-products.test.mjs",
    "test:data": "node scripts/validate-data.mjs",
    "test:smoke": "playwright test",
    "check": "pnpm lint:js && pnpm audit:app && pnpm data:check && pnpm test:data && pnpm test:search && pnpm test:ids && pnpm test:address-ids && pnpm test:product-ids && pnpm test:burst-random-boosters && pnpm test:burst-random-layers && pnpm test:x-tool-products && pnpm test:x-set-products && pnpm test:smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "eslint": "^9.31.0"
  }
}
